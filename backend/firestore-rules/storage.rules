rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /profile_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /photos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /listings/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /chats/{chatId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participantIds;
      allow write: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participantIds
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
